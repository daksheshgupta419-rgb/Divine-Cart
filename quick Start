# 1. Clone your repository
git clone https://github.com/daksheshgupta419/divine-cart.git
cd divine-cart

# 2. Install all dependencies
npm install

# 3. Install iOS pods (if on Mac)
cd ios && pod install && cd ..

# 4. Configure Firebase (IMPORTANT!)
# Edit: src/config/firebase.ts
# Get credentials from: https://console.firebase.google.com
# Replace: YOUR_API_KEY, YOUR_AUTH_DOMAIN, etc.

# 5. Run the app

# For Android:
npm run android

# For iOS:
npm run ios
